<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Page Not Found &ndash; Glondia</title>
  <link rel="stylesheet" href="site.css" />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body id="page--404" class="page">
  <main id="content" class="content" tabindex="-1">
    <section class="section">
      <div class="container not-found">
        <div class="card not-found__card">
          <h1 class="section__title">This page could not be found.</h1>
          <p class="section__intro">The link may be outdated, the address may be wrong, or the page may have moved.</p>
          <div class="not-found__actions">
            <a href="index" class="btn btn--primary">Back Home</a>
            <a href="contact" class="btn btn--ghost">Contact Glondia</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="site.js" defer></script>
</body>
</html>
