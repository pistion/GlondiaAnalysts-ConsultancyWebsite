          <article class="card card--project-compact" data-tags="current it">
            <div class="thumb thumb--project thumb--current thumb--roxanneai">
              <span class="project-media-badge">Current Project</span>
            </div>
            <div class="card__body card__body--project">
              <div class="project-header">
                <h3 class="card__title card__title--project">RoxanneAI</h3>
                <p class="project-kicker">Platform Development Report</p>
              </div>
              <p class="muted project-summary">An AI platform for generation, secure credit-managed workflows, and project-aware website editing through the Roxanne SiteCraft environment.</p>
              <div class="project-footer">
                <div class="project-metrics" aria-label="Project highlights">
                  <span class="project-metric"><i class="fa-regular fa-file-lines" aria-hidden="true"></i><span>2026 report</span></span>
                  <span class="project-metric"><i class="fa-solid fa-robot" aria-hidden="true"></i><span>4 key functions</span></span>
                </div>
                <div class="project-actions">
                  <a href="files/roxanneai-development-report.pdf" class="btn btn--primary btn--sm" target="_blank" rel="noopener">PDF Report</a>
                  <a href="https://roxanneai-n1as.onrender.com/" class="btn btn--ghost btn--sm" target="_blank" rel="noopener">Website</a>
                </div>
              </div>
              <div id="roxanneai-details" class="project-details" aria-hidden="true">
                <div class="project-details__inner">
                  <p class="project-details__label">Key functions</p>
                  <ul class="project-functions">
                    <li>Modular intent orchestration across extraction, dispatching, parsing, validation, and normalization layers.</li>
                    <li>Text, image, voice, and video generation backed by credit controls, token trimming, and quota-safe error handling.</li>
                    <li>SiteCraft AI editing with Monaco IDE workflows, virtual file caching, live preview, and deployment-ready update flow.</li>
                    <li>Deep project indexing and dependency mapping so the assistant can understand and edit sites with real project context.</li>
                  </ul>
                  <div class="tags"><span class="tag">AI Platform</span><span class="tag">SiteCraft</span><span class="tag">Automation</span><span class="tag">Intelligent Editing</span></div>
                </div>
              </div>
              <button
                class="project-toggle project-toggle--footer"
                type="button"
                aria-expanded="false"
                aria-controls="roxanneai-details"
                aria-label="Show key functions"
              >
                <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
              </button>
            </div>
          </article>

