  <main id="content" class="content" tabindex="-1">

    <section id="consultants" class="section consultants">
      <div class="container">
        <h2 class="section__title">Meet Our Consultants</h2>
        <p class="section__intro">Our team of consultants brings deep expertise across analytics, economics, finance, and strategy. Learn more and reach out directly to collaborate.</p>

        <div id="consultants-filters" class="filters" aria-label="Consultant filters">
          <button class="chip is-active" data-filter="all">All</button>
          <button class="chip" data-filter="analytics">Analytics</button>
          <button class="chip" data-filter="finance">Finance</button>
          <button class="chip" data-filter="economics">Economics</button>
          <button class="chip" data-filter="strategy">Strategy</button>
        </div>

        <div id="consultants-grid" class="grid">
          <article class="card" data-tags="analytics">
            <div class="thumb"><img src="assets/img/consultants/alex.png" alt="Alex Consultant Portrait"></div>
            <div class="card__body">
              <h3 class="card__title">Alex Johnson</h3>
              <p class="muted">Senior Data Analyst specializing in predictive modeling, business intelligence, and process optimization.</p>
              <div class="tags"><span class="tag">PowerBI</span><span class="tag">Python</span><span class="tag">Machine Learning</span></div>
              <div class="cta-row">
                <a href="assets/cv/AlexJohnson_CV.pdf" class="btn btn--primary btn--sm" target="_blank">View CV</a>
                <a href="assets/cv/AlexJohnson_CV.pdf" class="btn btn--ghost btn--sm" download>Download CV</a>
                <a href="mailto:alex.johnson@glondia.com" class="btn btn--outline btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>

          <article class="card" data-tags="finance">
            <div class="thumb"><img src="assets/img/consultants/maria.png" alt="Maria Consultant Portrait"></div>
            <div class="card__body">
              <h3 class="card__title">Maria Lopez</h3>
              <p class="muted">Financial analyst with experience in investment appraisals, corporate valuations, and risk assessment.</p>
              <div class="tags"><span class="tag">NPV</span><span class="tag">IRR</span><span class="tag">Valuation</span></div>
              <div class="cta-row">
                <a href="assets/cv/MariaLopez_CV.pdf" class="btn btn--primary btn--sm" target="_blank">View CV</a>
                <a href="assets/cv/MariaLopez_CV.pdf" class="btn btn--ghost btn--sm" download>Download CV</a>
                <a href="mailto:maria.lopez@glondia.com" class="btn btn--outline btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>

          <article class="card" data-tags="economics">
            <div class="thumb"><img src="assets/img/consultants/david.png" alt="David Consultant Portrait"></div>
            <div class="card__body">
              <h3 class="card__title">David Kora</h3>
              <p class="muted">Economic policy expert focusing on market studies, SME growth, and development finance strategy.</p>
              <div class="tags"><span class="tag">Econometrics</span><span class="tag">Policy</span><span class="tag">SME Development</span></div>
              <div class="cta-row">
                <a href="assets/cv/DavidKora_CV.pdf" class="btn btn--primary btn--sm" target="_blank">View CV</a>
                <a href="assets/cv/DavidKora_CV.pdf" class="btn btn--ghost btn--sm" download>Download CV</a>
                <a href="mailto:david.kora@glondia.com" class="btn btn--outline btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>

          <article class="card" data-tags="strategy">
            <div class="thumb"><img src="assets/img/consultants/sophia.png" alt="Sophia Consultant Portrait"></div>
            <div class="card__body">
              <h3 class="card__title">Sophia Tane</h3>
              <p class="muted">Strategy consultant helping organizations align data insights with long-term growth goals.</p>
              <div class="tags"><span class="tag">Corporate Strategy</span><span class="tag">Planning</span><span class="tag">Leadership</span></div>
              <div class="cta-row">
                <a href="assets/cv/SophiaTane_CV.pdf" class="btn btn--primary btn--sm" target="_blank">View CV</a>
                <a href="assets/cv/SophiaTane_CV.pdf" class="btn btn--ghost btn--sm" download>Download CV</a>
                <a href="mailto:sophia.tane@glondia.com" class="btn btn--outline btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>
