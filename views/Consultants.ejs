  <main id="content" class="content" tabindex="-1">
    <section id="consultants" class="section consultants">
      <div class="container">
        <h2 class="section__title">Meet Our Consultants</h2>
        <p class="section__intro">Our consultants bring experience across analytics, economics, finance, and strategy. Learn more about their focus areas and get in touch directly.</p>

        <div id="consultants-filters" class="filters" aria-label="Consultant filters">
          <button class="chip is-active" data-filter="all">All</button>
          <button class="chip" data-filter="analytics">Analytics</button>
          <button class="chip" data-filter="finance">Finance</button>
          <button class="chip" data-filter="economics">Economics</button>
          <button class="chip" data-filter="strategy">Strategy</button>
        </div>

        <div class="grid">
          <article class="card" data-tags="analytics">
            <div class="thumb thumb--portrait thumb--analytics">
              <span class="thumb__eyebrow">Analytics</span>
              <h3 class="thumb__title">Alex Johnson</h3>
            </div>
            <div class="card__body">
              <h3 class="card__title">Alex Johnson</h3>
              <p class="muted">Senior data analyst specializing in predictive modeling, business intelligence, and process optimization.</p>
              <div class="tags"><span class="tag">PowerBI</span><span class="tag">Python</span><span class="tag">Machine Learning</span></div>
              <div class="cta-row">
                <a href="mailto:alex.johnson@glondia.com" class="btn btn--primary btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>

          <article class="card" data-tags="finance">
            <div class="thumb thumb--portrait thumb--finance">
              <span class="thumb__eyebrow">Finance</span>
              <h3 class="thumb__title">Maria Lopez</h3>
            </div>
            <div class="card__body">
              <h3 class="card__title">Maria Lopez</h3>
              <p class="muted">Financial analyst with experience in investment appraisal, valuation, and risk assessment.</p>
              <div class="tags"><span class="tag">NPV</span><span class="tag">IRR</span><span class="tag">Valuation</span></div>
              <div class="cta-row">
                <a href="mailto:maria.lopez@glondia.com" class="btn btn--primary btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>

          <article class="card" data-tags="economics">
            <div class="thumb thumb--portrait thumb--economics">
              <span class="thumb__eyebrow">Economics</span>
              <h3 class="thumb__title">David Kora</h3>
            </div>
            <div class="card__body">
              <h3 class="card__title">David Kora</h3>
              <p class="muted">Economic policy expert focused on market studies, SME growth, and development finance strategy.</p>
              <div class="tags"><span class="tag">Econometrics</span><span class="tag">Policy</span><span class="tag">SME Development</span></div>
              <div class="cta-row">
                <a href="mailto:david.kora@glondia.com" class="btn btn--primary btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>

          <article class="card" data-tags="strategy">
            <div class="thumb thumb--portrait thumb--strategy">
              <span class="thumb__eyebrow">Strategy</span>
              <h3 class="thumb__title">Sophia Tane</h3>
            </div>
            <div class="card__body">
              <h3 class="card__title">Sophia Tane</h3>
              <p class="muted">Strategy consultant helping organizations align data insights with long-term growth goals.</p>
              <div class="tags"><span class="tag">Corporate Strategy</span><span class="tag">Planning</span><span class="tag">Leadership</span></div>
              <div class="cta-row">
                <a href="mailto:sophia.tane@glondia.com" class="btn btn--primary btn--sm"><i class="fa-solid fa-envelope"></i> Message</a>
              </div>
            </div>
          </article>
        </div>
      </div>
