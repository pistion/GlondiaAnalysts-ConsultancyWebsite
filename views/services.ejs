  <main id="content" class="content" tabindex="-1">

    <section id="services" class="section services">
      <div class="container">
        <h2 class="section__title">Full-Service Analytics & Consulting</h2>
        <p class="muted">From IT & Data to Economic and Financial analysis—custom reports, dashboards, and actionable recommendations.</p>
        <div class="service-grid">
          <article class="service card">
            <h3 class="service__title">IT &amp; Data Analysis</h3>
            <ul class="service__list">
              <li>Data collection &amp; cleaning</li>
              <li>Descriptive &amp; diagnostic analytics</li>
              <li>Predictive &amp; prescriptive analytics</li>
              <li>Big data &amp; AI solutions</li>
              <li>Visualization &amp; dashboards</li>
              <li>Time series &amp; trend analysis</li>
              <li>Text &amp; sentiment analysis</li>
              <li>Data mining &amp; pattern discovery</li>
            </ul>
          </article>
          <article class="service card">
            <h3 class="service__title">Economic Analysis</h3>
            <ul class="service__list">
              <li>Micro &amp; macroeconomic analysis</li>
              <li>Cost-benefit &amp; feasibility studies</li>
              <li>Trade &amp; globalization insights</li>
              <li>Econometric &amp; statistical modeling</li>
              <li>Supply &amp; demand analysis</li>
              <li>Forecasting &amp; scenario planning</li>
            </ul>
          </article>
          <article class="service card">
            <h3 class="service__title">Financial &amp; Accounting</h3>
            <ul class="service__list">
              <li>Financial statements review</li>
              <li>Ratio &amp; performance analysis</li>
              <li>Cost analysis &amp; budgeting</li>
              <li>Investment appraisal (NPV, IRR, payback)</li>
              <li>Variance analysis</li>
              <li>Forensic accounting &amp; fraud detection</li>
              <li>Tax planning &amp; compliance</li>
            </ul>
          </article>
          <article class="service card">
            <h3 class="service__title">Business &amp; Strategy</h3>
            <ul class="service__list">
              <li>SWOT, PESTLE, Porter’s Five Forces</li>
              <li>Market &amp; competitor analysis</li>
              <li>Customer &amp; behavioral analysis</li>
              <li>Performance &amp; KPI monitoring</li>
              <li>Risk management &amp; scenario analysis</li>
            </ul>
          </article>
          <article class="service card">
            <h3 class="service__title">Specialized &amp; Cross-Functional</h3>
            <ul class="service__list">
              <li>Policy &amp; regulatory impact analysis</li>
              <li>Environmental &amp; sustainability analysis</li>
              <li>Healthcare, social, and demographic analytics</li>
              <li>Operations &amp; supply chain analysis</li>
            </ul>
          </article>
          <article class="service card">
            <h3 class="service__title">Deliverables &amp; Value</h3>
            <ul class="service__list">
              <li>Custom reports &amp; dashboards</li>
              <li>Actionable recommendations</li>
              <li>Workshops &amp; training</li>
              <li>Ongoing monitoring &amp; advisory support</li>
            </ul>
          </article>

          <!-- ===== Added HR Services (kept same structure & classes) ===== -->
          <article class="service card">
            <h3 class="service__title">Human Resources (HR) Services</h3>
            <ul class="service__list">
              <li>Recruitment &amp; talent acquisition</li>
              <li>Onboarding &amp; offboarding programs</li>
              <li>Performance management frameworks (OKRs/KPIs)</li>
              <li>Employee relations &amp; engagement</li>
              <li>Policy drafting &amp; handbook development</li>
              <li>Workforce planning &amp; org design</li>
              <li>Compliance &amp; workplace investigations</li>
            </ul>
          </article>

          <article class="service card">
            <h3 class="service__title">Compensation, Benefits &amp; HR Ops</h3>
            <ul class="service__list">
              <li>Compensation benchmarking &amp; salary structures</li>
              <li>Benefits design &amp; administration</li>
              <li>Payroll setup, audits &amp; optimization</li>
              <li>Leave management &amp; attendance</li>
              <li>Learning &amp; development (L&amp;D) programs</li>
              <li>HRIS selection, rollout &amp; support</li>
              <li>HR process mapping &amp; SOPs</li>
            </ul>
          </article>
          <!-- ===== /Added HR Services ===== -->

        </div>
      </div>
