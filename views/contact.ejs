<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Contact – Glondia</title>

  <!-- Global Styles -->
  <link rel="stylesheet" href="site.css" />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body id="page--contact" class="page">

  <!-- === Header === -->
  <header id="site-header" class="site-header" role="banner">
    <div class="container header__inner">
      <a class="brand" href="index" aria-label="Glondia home">
        <img class="brand__logo" src="imgs/logo.png" alt="Glondia logo" />
        <span class="brand__name">Glondia</span>
      </a>

      <nav id="primary-nav" class="nav" aria-label="Primary">
        <a class="nav__link" href="index" data-nav="home">Home</a>
        <a class="nav__link" href="portfolio" data-nav="portfolio">Portfolio</a>
        <a class="nav__link" href="portfolio" data-nav="portfolio">Research</a>
        <a class="nav__link" href="portfolio" data-nav="portfolio">Services</a>
        <a class="nav__link" href="Consultants" data-nav="services">Consultants</a>
        <a class="nav__link" href="contact" data-nav="contact">Contact</a>
        <a class="nav__link" href="about" data-nav="about">About</a>
        <a class="nav__link" href="AI-Coming_soonPage" data-nav="about">AI Chat</a>    <!-- Analyist, FrontDesk, Taxadvisor, Advisor -->
      </nav>

      <button id="hamburger" class="hamburger" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
    
 <!-- Mobile menu (toggled by #hamburger) -->
    <div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Mobile Menu">
  <a href="" class="mobile-menu__link"><i class="fas fa-home"></i> Home</a>
  <a href="portfolio" class="mobile-menu__link"><i class="fas fa-briefcase"></i> Portfolio</a>
  <a href="Research" class="mobile-menu__link"><i class="fas fa-flask"></i> Research</a>
  <a href="services" class="mobile-menu__link"><i class="fas fa-cogs"></i> Services</a>
  <a href="Consultants" class="mobile-menu__link"><i class="fas fa-users"></i> Consultants</a>
  <a href="contact" class="mobile-menu__link"><i class="fas fa-envelope"></i> Contact</a>
  <a href="about" class="mobile-menu__link"><i class="fas fa-info-circle"></i> About</a>
  <a href="AI-Coming_soonPage" class="mobile-menu__link"><i class="fas fa-robot"></i> AI Chat</a>
    </div>
  </header>

  <!-- === Main Content === -->
  <main id="content" class="content" tabindex="-1">
    <section id="contact" class="section contact">
      <div class="container">
        <h2 class="section__title">Contact</h2>
        <div class="contact-grid">
          <div class="contact-card"><i class="fa-brands fa-whatsapp"></i> <strong>WhatsApp:</strong> +675 7823 8214</div>
          <div class="contact-card"><i class="fa-regular fa-envelope"></i> <strong>Email:</strong> <a href="mailto:glondia@outlook.com">glondia@outlook.com</a></div>
          <div class="contact-card"><i class="fa-solid fa-video"></i> <strong>Zoom:</strong> Glondia_Online</div>
        </div>
      </div>
    </section>

    <section id="message" class="section message">
      <div class="container">
        <h2 class="section__title"><i class="fa-regular fa-paper-plane"></i> Leave Me A Message</h2>
        <p class="section__intro">Have a question, proposal, or just want to say hello? I’d love to hear from you!</p>

       <form id="contactForm" class="message-form">
    <div class="form-grid">
      <div class="form-group">
        <label for="name">Your Name</label>
        <input type="text" id="name" name="name" placeholder="Enter your name" required />
      </div>
      <div class="form-group">
        <label for="email">Your Email</label>
        <input type="email" id="email" name="email" placeholder="Enter your email" required />
      </div>
    </div>

    <div class="form-group">
      <label for="message-text">Your Message</label>
      <textarea id="message-text" name="message" rows="6" placeholder="Type your inquiry here..." required></textarea>
    </div>

    <button type="submit" class="btn btn--primary">
      <i class="fa-solid fa-paper-plane"></i> Send Message
    </button>
  </form>

      </div>
    </section>
  </main>

   <!-- === Global Footer === -->
  <footer id="site-footer" class="site-footer">
    <div class="container footer__grid">
      <section class="footer__col">
        <h4 class="footer__title">Glondia</h4>
        <p class="footer__text">We partner with SMEs to deliver analytics, economics, finance, and strategy—turning insights into growth.</p>
      </section>
      <section class="footer__col">
        <h4 class="footer__title">Links</h4>
        <ul class="footer__list">
          <li><a class="footer__link" href="index">Home</a></li>
          <li><a class="footer__link" href="services">Services</a></li>
          <li><a class="footer__link" href="portfolio">Portfolio</a></li>
          <li><a class="footer__link" href="about">About</a></li>
          <li><a class="footer__link" href="contact">Contact</a></li>
        </ul>
      </section>
      <section class="footer__col">
        <h4 class="footer__title">Action</h4>
        <p><button class="btn btn--primary" id="apply-btn" type="button">Apply Now</button></p>
        <small>© <span id="year"></span> Glondia Analysts &amp; Consultancy</small>
      </section>
    </div>
  </footer>
  <script src="site.js"></script>
</body>
</html>

