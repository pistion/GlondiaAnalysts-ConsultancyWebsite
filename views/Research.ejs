<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Portfolio – Glondia</title>
  <!-- Global, consolidated stylesheet for ALL pages -->
  <link rel="stylesheet" href="site.css" />
  <!-- Font Awesome for icons -->
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body id="page--portfolio" class="page">
  <!-- === Global Header (note: role='navigation') === -->
  <header id="site-header" class="site-header" role="banner">
    <div class="container header__inner">
      <a class="brand" id="brand" href="index" aria-label="Glondia home">
        <img class="brand__logo" src="imgs/logo.png" alt="Glondia logo" />
        <span class="brand__name">Glondia</span>
      </a>

      <!-- Primary nav (use class & id, keep semantic nav element) -->
      <nav id="primary-nav" class="nav" aria-label="Primary">
      <a class="nav__link" href="index" data-nav="home">Home</a>
        <a class="nav__link" href="portfolio" data-nav="portfolio">Portfolio</a>
        <a class="nav__link" href="portfolio" data-nav="portfolio">Research</a>
        <a class="nav__link" href="portfolio" data-nav="portfolio">Services</a>
        <a class="nav__link" href="Consultants" data-nav="services">Consultants</a>
        <a class="nav__link" href="contact" data-nav="contact">Contact</a>
        <a class="nav__link" href="about" data-nav="about">About</a>
        <a class="nav__link" href="AI-Coming_soonPage" data-nav="about">AI Chat</a>    <!-- Analyist, FrontDesk, Taxadvisor, Advisor -->
      </nav>
      </nav>

      <button id="hamburger" class="hamburger" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>

    <!-- Mobile menu (toggled by #hamburger) -->
    <div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Mobile Menu">
  <a href="" class="mobile-menu__link"><i class="fas fa-home"></i> Home</a>
  <a href="portfolio" class="mobile-menu__link"><i class="fas fa-briefcase"></i> Portfolio</a>
  <a href="Research" class="mobile-menu__link"><i class="fas fa-flask"></i> Research</a>
  <a href="services" class="mobile-menu__link"><i class="fas fa-cogs"></i> Services</a>
  <a href="Consultants" class="mobile-menu__link"><i class="fas fa-users"></i> Consultants</a>
  <a href="contact" class="mobile-menu__link"><i class="fas fa-envelope"></i> Contact</a>
  <a href="about" class="mobile-menu__link"><i class="fas fa-info-circle"></i> About</a>
  <a href="AI-Coming_soonPage" class="mobile-menu__link"><i class="fas fa-robot"></i> AI Chat</a>
    </div>
  </header>

  <main id="content" class="content" tabindex="-1">

    <section id="portfolio" class="section portfolio">
      <div class="container">
        <h2 class="section__title">Our Portfolio of Reports & Research</h2>
        <div id="portfolio-filters" class="filters" aria-label="Portfolio filters">
          <!-- Clicking a .chip sets data-filter and shows matching .card[data-tags*='filter'] -->
          <button class="chip is-active" data-filter="all">All</button>
          <button class="chip" data-filter="it">IT &amp; Data Analysis</button>
          <button class="chip" data-filter="economic">Economic Analysis</button>
          <button class="chip" data-filter="financial">Financial Analysis</button>
        </div>

        <div id="portfolio-grid" class="grid">
          <article class="card" data-tags="it">
            <div class="thumb">Dashboard Preview</div>
            <div class="card__body">
              <h3 class="card__title">Customer Behavior Analysis 2024</h3>
              <p class="muted">An in‑depth analysis of customer purchase behavior across digital channels.</p>
              <div class="tags"><span class="tag">PowerBI</span><span class="tag">SQL</span><span class="tag">Time‑series</span></div>
              <div class="cta-row">
                <button class="btn btn--primary btn--sm">View Report</button>
                <button class="btn btn--ghost btn--sm">Download PDF</button>
              </div>
            </div>
          </article>

          <article class="card" data-tags="economic">
            <div class="thumb">Market Study</div>
            <div class="card__body">
              <h3 class="card__title">PNG SME Market Outlook</h3>
              <p class="muted">Macroeconomic trends, policy impacts, and SME growth opportunities.</p>
              <div class="tags"><span class="tag">Econometrics</span><span class="tag">Forecasting</span></div>
              <div class="cta-row">
                <button class="btn btn--primary btn--sm">View Report</button>
                <button class="btn btn--ghost btn--sm">Download PDF</button>
              </div>
            </div>
          </article>

          <article class="card" data-tags="financial">
            <div class="thumb">Financial Review</div>
            <div class="card__body">
              <h3 class="card__title">Investment Appraisal – Retail Expansion</h3>
              <p class="muted">NPV, IRR, and payback evaluation for a multi‑store rollout scenario.</p>
              <div class="tags"><span class="tag">NPV</span><span class="tag">IRR</span><span class="tag">Sensitivity</span></div>
              <div class="cta-row">
                <button class="btn btn--primary btn--sm">View Report</button>
                <button class="btn btn--ghost btn--sm">Download PDF</button>
              </div>
            </div>
          </article>

          <article class="card" data-tags="it">
            <div class="thumb">Text Mining</div>
            <div class="card__body">
              <h3 class="card__title">Sentiment Analysis – Product Feedback</h3>
              <p class="muted">Extracting themes and tone from customer reviews to inform roadmap.</p>
              <div class="tags"><span class="tag">NLP</span><span class="tag">Python</span></div>
              <div class="cta-row">
                <button class="btn btn--primary btn--sm">View Report</button>
                <button class="btn btn--ghost btn--sm">Download PDF</button>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

  </main>

  <!-- === Global Footer === -->
  <footer id="site-footer" class="site-footer">
    <div class="container footer__grid">
      <section class="footer__col">
        <h4 class="footer__title">Glondia</h4>
        <p class="footer__text">We partner with SMEs to deliver analytics, economics, finance, and strategy—turning insights into growth.</p>
      </section>
      <section class="footer__col">
        <h4 class="footer__title">Links</h4>
        <ul class="footer__list">
          <li><a class="footer__link" href="index">Home</a></li>
          <li><a class="footer__link" href="services">Services</a></li>
          <li><a class="footer__link" href="portfolio">Portfolio</a></li>
          <li><a class="footer__link" href="about">About</a></li>
          <li><a class="footer__link" href="contact">Contact</a></li>
        </ul>
      </section>
      <section class="footer__col">
        <h4 class="footer__title">Action</h4>
        <p><button class="btn btn--primary" id="apply-btn" type="button">Apply Now</button></p>
        <small>© <span id="year"></span> Glondia Analysts &amp; Consultancy</small>
      </section>
    </div>
  </footer>

  <!-- Global script -->
  <script src="site.js" defer></script>
</body>
</html>
