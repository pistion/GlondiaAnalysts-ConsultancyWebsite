<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <base href="/" />
  <title>Publications &ndash; Glondia</title>
  <link rel="stylesheet" href="site.css" />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body id="page--publications" class="page">
  <header id="site-header" class="site-header" role="banner">
    <div class="container header__inner">
      <a class="brand" id="brand" href="index" aria-label="Glondia home">
        <img class="brand__logo" src="imgs/logo.png" alt="Glondia logo" />
        <span class="brand__name">Glondia</span>
      </a>

      <nav id="primary-nav" class="nav" aria-label="Primary">
        <a class="nav__link" href="index">Home</a>
        <a class="nav__link" href="portfolio">Portfolio</a>
        <div class="nav__item nav__item--has-menu">
          <a class="nav__link" href="publications">Publications</a>
          <div class="nav__dropdown" aria-label="Publications categories">
            <a class="nav__dropdown-link" href="publications/articles">Articles</a>
            <a class="nav__dropdown-link" href="publications#reports">Reports</a>
            <a class="nav__dropdown-link" href="publications#research">Research</a>
          </div>
        </div>
        <a class="nav__link" href="services">Services</a>
        <a class="nav__link" href="Consultants">Consultants</a>
        <a class="nav__link" href="contact">Contact</a>
        <a class="nav__link" href="about">About</a>
      </nav>

      <button id="hamburger" class="hamburger" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>

    <div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Mobile Menu">
      <a href="index" class="mobile-menu__link"><i class="fas fa-home"></i> Home</a>
      <a href="portfolio" class="mobile-menu__link"><i class="fas fa-briefcase"></i> Portfolio</a>
      <div class="mobile-menu__group mobile-menu__group--has-submenu">
        <div class="mobile-menu__group-head">
          <a href="publications" class="mobile-menu__link mobile-menu__link--parent"><i class="fas fa-newspaper"></i> Publications</a>
          <button class="mobile-menu__toggle" type="button" aria-label="Open Publications menu" aria-expanded="false" aria-controls="mobile-publications-submenu">
            <i class="fa-solid fa-chevron-down"></i>
          </button>
        </div>
        <div id="mobile-publications-submenu" class="mobile-menu__submenu" aria-hidden="true">
          <a href="publications/articles" class="mobile-menu__link mobile-menu__link--sub"><i class="fas fa-file-lines"></i> Articles</a>
          <a href="publications#reports" class="mobile-menu__link mobile-menu__link--sub"><i class="fas fa-chart-column"></i> Reports</a>
          <a href="publications#research" class="mobile-menu__link mobile-menu__link--sub"><i class="fas fa-book-open"></i> Research</a>
        </div>
      </div>
      <a href="services" class="mobile-menu__link"><i class="fas fa-cogs"></i> Services</a>
      <a href="Consultants" class="mobile-menu__link"><i class="fas fa-users"></i> Consultants</a>
      <a href="contact" class="mobile-menu__link"><i class="fas fa-envelope"></i> Contact</a>
      <a href="about" class="mobile-menu__link"><i class="fas fa-info-circle"></i> About</a>
    </div>
  </header>

  <main id="content" class="content" tabindex="-1">
    <section class="section publications-page">
      <div class="container">
        <div class="publications-shell">
          <section class="publications-hero">
            <p class="publications-eyebrow">Publications</p>
            <h1 class="publications-title">Articles, reports, and research in one place.</h1>
            <p class="publications-intro">
              Browse Glondia writing, business reports, and research-facing publications. Use the categories below to move between each publication type.
            </p>
          </section>

          <section class="publications-browser">
            <div class="filters publications-filters" aria-label="Publication categories">
              <button class="chip is-active" type="button" data-filter="all">All</button>
              <button class="chip" type="button" data-filter="articles">Articles</button>
              <button class="chip" type="button" data-filter="reports">Reports</button>
              <button class="chip" type="button" data-filter="research">Research</button>
            </div>

            <div class="grid publications-grid">
              <article id="articles" class="card publications-entry publications-entry--article" data-tags="articles">
                <a class="publications-entry__media publications-entry__media--article" href="publications/articles" aria-label="Open the article library">
                  <span class="publications-entry__media-badge">Article library</span>
                </a>
                <div class="publications-entry__body">
                  <div class="publications-entry__head">
                    <p class="publications-entry__type">Articles 01</p>
                    <span class="publications-entry__date">Archive open</span>
                  </div>
                  <h2 class="publications-entry__title"><a class="publications-entry__link" href="publications/articles">Article Library</a></h2>
                  <p class="publications-entry__strap">Published Glondia articles and archive entries</p>
                  <p class="publications-entry__summary">
                    Open the article archive to browse published pieces in one organized list. The current library includes <strong>Sustainable Development</strong> and is set up for future articles to be added in sequence.
                  </p>
                  <div class="publications-entry__actions">
                    <a class="btn btn--primary publications-entry__button" href="publications/articles">Open Library</a>
                    <a class="btn btn--ghost publications-entry__button" href="publications/sustainable-development">Latest Article</a>
                  </div>
                </div>
              </article>

              <article id="reports" class="card publications-entry publications-entry--report" data-tags="reports">
                <span class="publications-entry__media publications-entry__media--report" aria-hidden="true">
                  <span class="publications-entry__media-badge">Reports library</span>
                </span>
                <div class="publications-entry__body">
                  <div class="publications-entry__head">
                    <p class="publications-entry__type">Reports 02</p>
                    <span class="publications-entry__date">Coming soon</span>
                  </div>
                  <h2 class="publications-entry__title">Business Reports Library</h2>
                  <p class="publications-entry__strap">Report publishing in progress</p>
                  <p class="publications-entry__summary">
                    Client-facing and internal reporting outputs will appear here as Glondia expands the publications library across business analysis, reporting packs, and project documentation.
                  </p>
                  <div class="publications-entry__actions">
                    <a class="btn btn--primary publications-entry__button" href="contact">Request Reports</a>
                  </div>
                </div>
              </article>

              <article id="research" class="card publications-entry publications-entry--research" data-tags="research">
                <span class="publications-entry__media publications-entry__media--research" aria-hidden="true">
                  <span class="publications-entry__media-badge">Research archive</span>
                </span>
                <div class="publications-entry__body">
                  <div class="publications-entry__head">
                    <p class="publications-entry__type">Research 03</p>
                    <span class="publications-entry__date">Coming soon</span>
                  </div>
                  <h2 class="publications-entry__title">Research Notes &amp; Briefs</h2>
                  <p class="publications-entry__strap">Research publications category</p>
                  <p class="publications-entry__summary">
                    This category is reserved for shorter research pieces, evidence briefs, and themed notes that support business, policy, and development conversations.
                  </p>
                  <div class="publications-entry__actions">
                    <a class="btn btn--primary publications-entry__button" href="contact">Start a Research Enquiry</a>
                  </div>
                </div>
              </article>
            </div>
          </section>
        </div>
      </div>
    </section>
  </main>

  <footer id="site-footer" class="site-footer">
    <div class="container footer__grid">
      <section class="footer__col">
        <h4 class="footer__title">Glondia</h4>
        <p class="footer__text">We partner with SMEs through analytics, economics, finance, and strategy so better decisions lead to stronger growth.</p>
      </section>
      <section class="footer__col">
        <h4 class="footer__title">Quick Links</h4>
        <ul class="footer__list">
          <li><a class="footer__link" href="index">Home</a></li>
          <li><a class="footer__link" href="services">Services</a></li>
          <li><a class="footer__link" href="publications">Publications</a></li>
          <li><a class="footer__link" href="portfolio">Portfolio</a></li>
          <li><a class="footer__link" href="contact">Contact</a></li>
        </ul>
      </section>
      <section class="footer__col">
        <h4 class="footer__title">Next Step</h4>
        <p><button class="btn btn--primary" id="apply-btn" type="button">Apply Now</button></p>
        <small>&copy; <span id="year"></span> Glondia Analysts &amp; Consultancy</small>
      </section>
    </div>
  </footer>

  <script src="site.js" defer></script>
</body>
</html>
